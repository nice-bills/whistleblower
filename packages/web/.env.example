# Optional RPC overrides (defaults use Zama SDK public endpoints)
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
VITE_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# WalletConnect (optional — enables mobile / QR connect)
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id

# Set to "true" only for local screen recording (mock wallet auto-connect)
# VITE_DEMO_MOCK_WALLET=true
